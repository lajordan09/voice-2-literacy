        }
        lines {
          text: "   ```"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "3. **Configure Environment Variables:**"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "   Copy the example environment file and add your Google Gemini API key:"
