          text: "  \"highlightedSegment\": \"The exact word or segment of the text we want the student to focus on editing (e.g. \'went\', or \'target\')\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  \"scaffoldType\": \"the_stop_sign\" | \"the_name_game\" | \"word_upgrade\" | \"evidence_check\","
