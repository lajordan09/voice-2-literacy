          text: "app.post(\"/api/chat\", async (req, res) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const { messages, stage, studentIdea, studentIdeaHistory, focusType, studentFrustrated } = req.body;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
