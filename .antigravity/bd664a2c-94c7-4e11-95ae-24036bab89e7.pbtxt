        }
        lines {
          text: "  \"hints\": [\"Hint option 1\", \"Hint option 2\", \"Hint option 3\"], // Useful for multiple choice or helpful suggestions. If it\'s a Word Upgrade, provide 3 \'Juicy Word\' replacements here!"
