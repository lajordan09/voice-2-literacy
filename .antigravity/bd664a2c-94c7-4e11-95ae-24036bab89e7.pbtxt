  file_change {
    absolute_path_uri: "file:///src/components/TeacherDashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { Search, Trash2, User, Check, Settings, Plus, Star, BarChart2, TrendingUp, Calendar, AlertCircle, FileSpreadsheet, RefreshCw, Layers } from \"lucide-react\";\nimport { Student, SessionLog } from \"../types\";\n\ninterface TeacherDashboardProps {\n  students: Student[];\n  sessionLogs: SessionLog[];\n  onRefreshData: () => void;\n}\n\nexport default function TeacherDashboard({\n  students,\n  sessionLogs,\n  onRefreshData,\n}: TeacherDashboardProps) {\n  const [searchTerm, setSearchTerm] = useState(\"\");\n  const [selectedFocusFilter, setSelectedFocusFilter] = useState(\"All\");\n  const [selectedEngagementFilter, setSelectedEngagementFilter] = useState(\"All\");\n  \n  // Custom lesson state variables\n  const [juicyWords, setJuicyWords] = useState<string[]>([\"went \342\236\224 galloped / scampered\", \"good \342\236\224 spectacular / magnificent\", \"said \342\236\224 bellows / whispers\"]);\n  const [newWordPair, setNewWordPair] = useState(\"\");\n  const [activeLessonTrack, setActiveLessonTrack] = useState(\"Balanced Scaffolding Track\");\n\n  // Calculate high-level statistics\n  const totalSessions = sessionLogs.length;\n  const avgEngagement = totalSessions > 0\n    ? parseFloat((sessionLogs.reduce((acc, curr) => acc + curr.engagement_score, 0) / totalSessions).toFixed(1))\n    : 0.0;\n\n  const focusBreakdown = sessionLogs.reduce((acc: Record<string, number>, curr) => {\n    acc[curr.skill_mastery_focus] = (acc[curr.skill_mastery_focus] || 0) + 1;\n    return acc;\n  }, {});\n\n  // Handle word addition\n  const handleAddJuicyWord = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newWordPair.trim()) return;\n    setJuicyWords([...juicyWords, newWordPair]);\n    setNewWordPair(\"\");\n  };\n\n  // Handle Delete Session Log\n  const handleDeleteSession = async (sessionId: string) => {\n    if (!confirm(\"Are you sure you want to delete this session log? This cannot be undone.\")) return;\n    try {\n      const res = await fetch(`/api/sessions/${sessionId}`, {\n        method: \"DELETE\",\n      });\n      if (res.ok) {\n        onRefreshData();\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  // Filter session logs\n  const filteredLogs = sessionLogs.filter((log) => {\n    const matchesSearch = log.studentName.toLowerCase().includes(searchTerm.toLowerCase()) ||\n                          log.raw_input.toLowerCase().includes(searchTerm.toLowerCase()) ||\n                          log.edited_version.toLowerCase().includes(searchTerm.toLowerCase());\n    \n    const matchesFocus = selectedFocusFilter === \"All\" || log.skill_mastery_focus === selectedFocusFilter;\n    const matchesEngagement = selectedEngagementFilter === \"All\" || log.engagement_score.toString() === selectedEngagementFilter;\n\n    return matchesSearch && matchesFocus && matchesEngagement;\n  });\n\n  return (\n    <div id=\"teacher-dashboard\" className=\"bg-slate-50 min-h-[600px] rounded-2xl border border-slate-200 shadow-sm p-4 md:p-6 space-y-6\">\n      \n      {/* Title Bar with Sync option */}\n      <div id=\"teacher-title-bar\" className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-200 pb-4\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-slate-900 flex items-center gap-2\">\n            <FileSpreadsheet className=\"w-6 h-6 text-indigo-600\" />\n            Voice2Literacy Teacher Console\n          </h1>\n          <p className=\"text-xs text-slate-500 font-medium\">Monitor speech-to-text transcriptions, COPS scaffolding metrics, and diagnostics.</p>\n        </div>\n\n        <button\n          id=\"refresh-data-btn\"\n          onClick={onRefreshData}\n          className=\"inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 rounded-xl text-xs font-bold transition-all border border-indigo-100\"\n        >\n          <RefreshCw className=\"w-3.5 h-3.5\" />\n          <span>Sync Real-Time Logs</span>\n        </button>\n      </div>\n\n      {/* Analytics Summary Panel */}\n      <div id=\"analytics-grid\" className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        \n        {/* Metric Card 1 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3\">\n          <div className=\"p-3 bg-indigo-50 text-indigo-600 rounded-lg\">\n            <Layers className=\"w-5 h-5\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block\">Completed Sessions</span>\n            <span className=\"text-xl font-bold text-slate-900\">{totalSessions}</span>\n          </div>\n        </div>\n\n        {/* Metric Card 2 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3\">\n          <div className=\"p-3 bg-amber-50 text-amber-600 rounded-lg\">\n            <Star className=\"w-5 h-5 fill-amber-500 text-amber-500\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block\">Avg. Engagement</span>\n            <span className=\"text-xl font-bold text-slate-900\">{avgEngagement} / 5</span>\n          </div>\n        </div>\n\n        {/* Metric Card 3 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3 col-span-1 sm:col-span-2\">\n          <div className=\"p-3 bg-emerald-50 text-emerald-600 rounded-lg self-start\">\n            <BarChart2 className=\"w-5 h-5\" />\n          </div>\n          <div className=\"flex-1\">\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1\">Scaffolding Focus Breakdown</span>\n            <div className=\"flex flex-wrap gap-2\">\n              {[\"Punctuation\", \"Capitalization\", \"Vocabulary Upgrading\", \"Elaboration\"].map((focus) => {\n                const count = focusBreakdown[focus] || 0;\n                const colors = {\n                  \"Punctuation\": \"bg-rose-50 text-rose-700 border-rose-100\",\n                  \"Capitalization\": \"bg-amber-50 text-amber-700 border-amber-100\",\n                  \"Vocabulary Upgrading\": \"bg-indigo-50 text-indigo-700 border-indigo-100\",\n                  \"Elaboration\": \"bg-emerald-50 text-emerald-700 border-emerald-100\",\n                }[focus];\n                return (\n                  <span key={focus} className={`text-[10px] font-semibold px-2 py-0.5 rounded-full border ${colors}`}>\n                    {focus}: <strong className=\"font-extrabold\">{count}</strong>\n                  </span>\n                );\n              })}\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Classroom Setup & Scaffolding customization */}\n      <div id=\"classroom-control-row\" className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Class Roster */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-200 shadow-xs lg:col-span-2 space-y-4\">\n          <h3 className=\"font-bold text-slate-900 text-sm flex items-center gap-1.5 border-b border-slate-100 pb-2\">\n            <User className=\"w-4 h-4 text-indigo-600\" />\n            Class Roster & Skill Badges\n          </h3>\n\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full text-left text-xs\">\n              <thead>\n                <tr className=\"border-b border-slate-100 text-slate-400 font-semibold uppercase tracking-wider\">\n                  <th className=\"pb-2\">Student</th>\n                  <th className=\"pb-2 text-center\">Sessions</th>\n                  <th className=\"pb-2 text-center\">Avg. Engagement</th>\n                  <th className=\"pb-2\">Mastered Skills</th>\n                  <th className=\"pb-2\">Recent Badge</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-slate-50\">\n                {students.map((student) => (\n                  <tr key={student.id} className=\"hover:bg-slate-50/50\">\n                    <td className=\"py-2.5 flex items-center gap-2\">\n                      <span className=\"text-xl bg-slate-50 p-1 rounded-lg\">{student.avatar}</span>\n                      <div>\n                        <div className=\"font-bold text-slate-900\">{student.name}</div>\n                        <div className=\"text-[10px] text-slate-400 font-semibold\">{student.grade}</div>\n                      </div>\n                    </td>\n                    <td className=\"py-2.5 text-center font-bold text-slate-700\">{student.completedSessions}</td>\n                    <td className=\"py-2.5 text-center\">\n                      <span className=\"inline-flex items-center gap-1 bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full font-bold\">\n                        <Star className=\"w-3 h-3 fill-amber-500 text-amber-500\" />\n                        {student.averageEngagement}\n                      </span>\n                    </td>\n                    <td className=\"py-2.5\">\n                      <div className=\"flex flex-wrap gap-1 max-w-[200px]\">\n                        {student.masteredSkills.map((skill) => (\n                          <span key={skill} className=\"bg-slate-100 text-slate-700 px-1.5 py-0.5 rounded-md text-[9px] font-semibold\">\n                            {skill}\n                          </span>\n                        ))}\n                        {student.masteredSkills.length === 0 && (\n                          <span className=\"text-slate-400 italic\">None yet</span>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"py-2.5\">\n                      <span className=\"bg-emerald-50 text-emerald-800 border border-emerald-100 px-2 py-0.5 rounded-full text-[10px] font-bold\">\n                        {student.recentBadge}\n                      </span>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n\n        {/* Lesson Scaffolding customizer */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-200 shadow-xs space-y-4\">\n          <h3 className=\"font-bold text-slate-900 text-sm flex items-center gap-1.5 border-b border-slate-100 pb-2\">\n            <Settings className=\"w-4 h-4 text-indigo-600\" />\n            Classroom Customizer\n          </h3>\n\n          {/* Configuration Track Selector */}\n          <div className=\"space-y-1.5\">\n            <label className=\"block text-xs font-bold text-slate-700\">Active Learning Track</label>\n            <select\n              value={activeLessonTrack}\n              onChange={(e) => setActiveLessonTrack(e.target.value)}\n              className=\"w-full text-xs bg-slate-50 border border-slate-200 rounded-xl p-2 font-medium text-slate-800 focus:outline-none focus:border-indigo-400\"\n            >\n              <option>Balanced Scaffolding Track (Default)</option>\n              <option>Heavy Vocabulary Upgrade Focus</option>\n              <option>Punctuation Mastery Track</option>\n              <option>Elaboration Expansion Mode</option>\n            </select>\n          </div>\n\n          {/* Juicy Words list */}\n          <div className=\"space-y-2\">\n            <label className=\"block text-xs font-bold text-slate-700\">Vocabulary Upgrades (Juicy Words)</label>\n            <div className=\"bg-slate-50 p-2.5 rounded-xl border border-slate-100 max-h-[110px] overflow-y-auto space-y-1\">\n              {juicyWords.map((word, i) => (\n                <div key={i} className=\"text-[10px] font-semibold text-slate-600 bg-white px-2 py-1 rounded-md border border-slate-100\">\n                  {word}\n                </div>\n              ))}\n            </div>\n\n            {/* Form to add words */}\n            <form onSubmit={handleAddJuicyWord} className=\"flex gap-1.5\">\n              <input\n                type=\"text\"\n                value={newWordPair}\n                onChange={(e) => setNewWordPair(e.target.value)}\n                placeholder=\"e.g., ran \342\236\224 sprinted\"\n                className=\"flex-1 bg-white border border-slate-200 rounded-lg px-2.5 py-1 text-xs focus:outline-none\"\n              />\n              <button\n                type=\"submit\"\n                className=\"bg-indigo-600 hover:bg-indigo-700 text-white p-1 rounded-lg\"\n              >\n                <Plus className=\"w-4 h-4\" />\n              </button>\n            </form>\n          </div>\n\n        </div>\n\n      </div>\n\n      {/* Real-time Session Logs (Comparison Matrix) */}\n      <div id=\"session-logs-section\" className=\"bg-white p-4 rounded-xl border border-slate-200 shadow-xs space-y-4\">\n        \n        {/* Section Header */}\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-slate-100 pb-3\">\n          <h3 className=\"font-bold text-slate-900 text-sm flex items-center gap-1.5\">\n            <Calendar className=\"w-4 h-4 text-indigo-600\" />\n            Historical Student Sessions & Comparison Logs\n          </h3>\n\n          {/* Total logs matching count */}\n          <span className=\"text-[10px] bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-bold\">\n            {filteredLogs.length} Records Found\n          </span>\n        </div>\n\n        {/* Filter Controls Bar */}\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-2\">\n          \n          {/* Search Input */}\n          <div className=\"relative md:col-span-2\">\n            <Search className=\"w-3.5 h-3.5 text-slate-400 absolute left-3 top-2.5\" />\n            <input\n              type=\"text\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              placeholder=\"Search student, raw transcripts, edits...\"\n              className=\"w-full text-xs bg-slate-50 border border-slate-200 rounded-xl pl-9 pr-3 py-2 text-slate-800 placeholder-slate-400 focus:outline-none focus:border-indigo-400\"\n            />\n          </div>\n\n          {/* Skill focus filter */}\n          <div>\n            <select\n              value={selectedFocusFilter}\n              onChange={(e) => setSelectedFocusFilter(e.target.value)}\n              className=\"w-full text-xs bg-slate-50 border border-slate-200 rounded-xl p-2 font-medium text-slate-700 focus:outline-none\"\n            >\n              <option value=\"All\">All Focuses</option>\n              <option value=\"Punctuation\">Punctuation</option>\n              <option value=\"Capitalization\">Capitalization</option>\n              <option value=\"Vocabulary Upgrading\">Vocabulary Upgrading</option>\n              <option value=\"Elaboration\">Elaboration</option>\n            </select>\n          </div>\n\n          {/* Engagement filter */}\n          <div>\n            <select\n              value={selectedEngagementFilter}\n              onChange={(e) => setSelectedEngagementFilter(e.target.value)}\n              className=\"w-full text-xs bg-slate-50 border border-slate-200 rounded-xl p-2 font-medium text-slate-700 focus:outline-none\"\n            >\n              <option value=\"All\">All Engagement Levels</option>\n              <option value=\"5\">5/5 Engagement</option>\n              <option value=\"4\">4/5 Engagement</option>\n              <option value=\"3\">3/5 Engagement</option>\n              <option value=\"2\">2/5 Engagement</option>\n              <option value=\"1\">1/5 Engagement</option>\n            </select>\n          </div>\n\n        </div>\n\n        {/* Logs Listing / Comparison Matrix */}\n        <div id=\"session-logs-list\" className=\"space-y-4\">\n          <AnimatePresence mode=\"popLayout\">\n            {filteredLogs.map((log) => (\n              <motion.div\n                key={log.id}\n                id={`session-log-card-${log.id}`}\n                layout\n                initial={{ opacity: 0, scale: 0.99 }}\n                animate={{ opacity: 1, scale: 1 }}\n                exit={{ opacity: 0, scale: 0.95 }}\n                className=\"p-4 bg-slate-50/50 hover:bg-slate-50 border border-slate-100 rounded-xl space-y-3 relative group transition-colors\"\n              >\n                {/* Log Header metadata */}\n                <div className=\"flex flex-wrap items-center justify-between gap-2\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"font-bold text-slate-900 text-xs\">{log.studentName}</span>\n                    <span className=\"text-[10px] text-slate-400 font-medium\">\n                      {new Date(log.timestamp).toLocaleString(undefined, {\n                        month: \"short\",\n                        day: \"numeric\",\n                        hour: \"2-digit\",\n                        minute: \"2-digit\",\n                      })}\n                    </span>\n                  </div>\n\n                  <div className=\"flex items-center gap-2\">\n                    {/* Focus Tag */}\n                    <span className={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${\n                      log.skill_mastery_focus === \"Punctuation\" ? \"bg-rose-50 text-rose-700 border-rose-100\" :\n                      log.skill_mastery_focus === \"Capitalization\" ? \"bg-amber-50 text-amber-700 border-amber-100\" :\n                      log.skill_mastery_focus === \"Vocabulary Upgrading\" ? \"bg-indigo-50 text-indigo-700 border-indigo-100\" :\n                      \"bg-emerald-50 text-emerald-800 border-emerald-100\"\n                    }`}>\n                      {log.skill_mastery_focus}\n                    </span>\n\n                    {/* Engagement score stars */}\n                    <span className=\"inline-flex gap-0.5\">\n                      {Array.from({ length: 5 }).map((_, idx) => (\n                        <Star\n                          key={idx}\n                          className={`w-3 h-3 ${idx < log.engagement_score ? \"fill-amber-500 text-amber-500\" : \"text-slate-200\"}`}\n                        />\n                      ))}\n                    </span>\n\n                    {/* Trash Button */}\n                    <button\n                      id={`delete-log-btn-${log.id}`}\n                      onClick={() => handleDeleteSession(log.id)}\n                      className=\"text-slate-400 hover:text-rose-600 p-1 rounded-md hover:bg-rose-50 transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100\"\n                    >\n                      <Trash2 className=\"w-3.5 h-3.5\" />\n                    </button>\n                  </div>\n                </div>\n\n                {/* Comparative Diffs Side by side */}\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {/* Left block: original spoken transcription */}\n                  <div className=\"bg-white p-3 rounded-xl border border-slate-100/80\">\n                    <span className=\"text-[9px] font-extrabold uppercase tracking-widest text-slate-400 block mb-1\">\n                      \360\237\223\235 Raw Spoken transcription:\n                    </span>\n                    <p className=\"text-xs text-slate-700 italic font-medium leading-relaxed\">\n                      \"{log.raw_input}\"\n                    </p>\n                  </div>\n\n                  {/* Right block: edited correct text */}\n                  <div className=\"bg-emerald-50/20 p-3 rounded-xl border border-emerald-100/50\">\n                    <span className=\"text-[9px] font-extrabold uppercase tracking-widest text-emerald-500 block mb-1\">\n                      \342\234\250 Polished Written Masterpiece:\n                    </span>\n                    <p className=\"text-xs text-emerald-950 font-bold italic leading-relaxed\">\n                      \"{log.edited_version}\"\n                    </p>\n                  </div>\n                </div>\n\n                {/* Analytical Diagnostics from Coach Voicey */}\n                <div className=\"bg-white/60 p-3 rounded-xl border border-slate-100 flex items-start gap-2\">\n                  <div className=\"bg-indigo-50 text-indigo-700 p-1.5 rounded-lg text-xs mt-0.5\">\n                    \360\237\244\226\n                  </div>\n                  <div className=\"space-y-0.5\">\n                    <span className=\"text-[9px] font-extrabold uppercase tracking-widest text-slate-400 block\">\n                      Coach Diagnostics & Scaffolding Notes:\n                    </span>\n                    <p className=\"text-xs text-slate-600 font-medium leading-relaxed\">\n                      {log.coach_notes}\n                    </p>\n                  </div>\n                </div>\n\n              </motion.div>\n            ))}\n\n            {filteredLogs.length === 0 && (\n              <div id=\"no-logs-alert\" className=\"text-center py-12 bg-slate-50 border border-slate-100 rounded-xl\">\n                <AlertCircle className=\"w-8 h-8 text-slate-300 mx-auto mb-2\" />\n                <h4 className=\"font-bold text-slate-700 text-sm\">No session logs match your filters</h4>\n                <p className=\"text-xs text-slate-400\">Complete sessions in the Student panel to populate logs!</p>\n              </div>\n            )}\n          </AnimatePresence>\n        </div>\n\n      </div>\n\n    </div>\n  );\n}\n"
