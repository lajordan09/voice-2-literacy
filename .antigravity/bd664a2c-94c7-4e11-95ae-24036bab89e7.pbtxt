        }
        lines {
          text: "- Frustration Handling: If the student indicates they are stuck, frustrated, or say \'i don\'t know\', instantly pivot to a \"Confidence Booster\". Give them a warm reminder of how amazing they are, and offer a simple choose-your-own-adventure hint or solve it together!"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
