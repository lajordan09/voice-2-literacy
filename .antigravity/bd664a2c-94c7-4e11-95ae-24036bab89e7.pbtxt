        target_content: "  return (\n    <div id=\"teacher-dashboard\" className=\"bg-slate-50 min-h-[600px] rounded-2xl border border-slate-200 shadow-sm p-4 md:p-6 space-y-6\">\n      \n      {/* Title Bar with Sync option */}\n      <div id=\"teacher-title-bar\" className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-200 pb-4\">\n        <div>\n          <h1 className=\"text-2xl font-bold text-slate-900 flex items-center gap-2\">\n            <FileSpreadsheet className=\"w-6 h-6 text-indigo-600\" />\n            Voice2Literacy Teacher Console\n          </h1>\n          <p className=\"text-xs text-slate-500 font-medium\">Monitor speech-to-text transcriptions, COPS scaffolding metrics, and diagnostics.</p>\n        </div>\n\n        <button\n          id=\"refresh-data-btn\"\n          onClick={onRefreshData}\n          className=\"inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 rounded-xl text-xs font-bold transition-all border border-indigo-100\"\n        >\n          <RefreshCw className=\"w-3.5 h-3.5\" />\n          <span>Sync Real-Time Logs</span>\n        </button>\n      </div>\n\n      {/* Analytics Summary Panel */}\n      <div id=\"analytics-grid\" className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        \n        {/* Metric Card 1 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3\">\n          <div className=\"p-3 bg-indigo-50 text-indigo-600 rounded-lg\">\n            <Layers className=\"w-5 h-5\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block\">Completed Sessions</span>\n            <span className=\"text-xl font-bold text-slate-900\">{totalSessions}</span>\n          </div>\n        </div>\n\n        {/* Metric Card 2 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3\">\n          <div className=\"p-3 bg-amber-50 text-amber-600 rounded-lg\">\n            <Star className=\"w-5 h-5 fill-amber-500 text-amber-500\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block\">Avg. Engagement</span>\n            <span className=\"text-xl font-bold text-slate-900\">{avgEngagement} / 5</span>\n          </div>\n        </div>\n\n        {/* Metric Card 3 */}\n        <div className=\"bg-white p-4 rounded-xl border border-slate-100 shadow-xs flex items-center gap-3 col-span-1 sm:col-span-2\">\n          <div className=\"p-3 bg-emerald-50 text-emerald-600 rounded-lg self-start\">\n            <BarChart2 className=\"w-5 h-5\" />\n          </div>\n          <div className=\"flex-1\">\n            <span className=\"text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1\">Scaffolding Focus Breakdown</span>\n            <div className=\"flex flex-wrap gap-2\">\n              {[\"Punctuation\", \"Capitalization\", \"Vocabulary Upgrading\", \"Elaboration\"].map((focus) => {\n                const count = focusBreakdown[focus] || 0;\n                const colors = {\n                  \"Punctuation\": \"bg-rose-50 text-rose-700 border-rose-100\",\n                  \"Capitalization\": \"bg-amber-50 text-amber-700 border-amber-100\",\n                  \"Vocabulary Upgrading\": \"bg-indigo-50 text-indigo-700 border-indigo-100\",\n                  \"Elaboration\": \"bg-emerald-50 text-emerald-700 border-emerald-100\",\n                }[focus];\n                return (\n                  <span key={focus} className={`text-[10px] font-semibold px-2 py-0.5 rounded-full border ${colors}`}>\n                    {focus}: <strong className=\"font-extrabold\">{count}</strong>\n                  </span>\n                );\n              })}\n            </div>\n          </div>\n        </div>\n\n      </div>"
