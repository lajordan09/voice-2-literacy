        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\224\204 How to Sync & Push to GitHub"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "This project is built and optimized for the **Google AI Studio Build** environment. To sync this repository directly to your personal GitHub account:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "1. **Locate the Settings Menu:** Look at the top right of the AI Studio Build interface."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "2. **Export to GitHub:** Click on the settings icon and select the **Export to GitHub** option."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "3. **Authorize and Link:** Log in with your GitHub account, grant the necessary permissions, and specify whether you want to export to a brand new repository or an existing one."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "4. **Push/Pull Updates:** Once connected, the platform manages your branch synchronizations automatically."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "---"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "## \360\237\244\235 Contributing"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "Contributions are what make the open-source community such an amazing place to learn, inspire, and create. Any contributions you make are **greatly appreciated**."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "1. Fork the Project"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "2. Create your Feature Branch (`git checkout -b feature/AmazingFeature`)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "3. Commit your Changes (`git commit -m \'Add some AmazingFeature\'`)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "4. Push to the Branch (`git push origin feature/AmazingFeature`)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "5. Open a Pull Request"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
